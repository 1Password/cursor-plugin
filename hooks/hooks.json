{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "./scripts/validate-mounted-env-files"
      }
    ],
    "preToolUse": [
      {
        "matcher": "Read",
        "command": "./scripts/deny-env-file-read"
      }
    ],
    "beforeReadFile": [
      {
        "command": "./scripts/deny-env-file-read"
      }
    ]
  }
}
